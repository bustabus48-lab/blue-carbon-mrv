# =============================================================================
# Blue Carbon MRV — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running the application.
#
#   cp .env.example .env
#
# NEVER commit the .env file — it is already listed in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (used by docker-compose and the backend)
# -----------------------------------------------------------------------------
POSTGRES_USER=mrv_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=bluecarbon

# Full async connection string for the FastAPI backend.
# When running via docker-compose the hostname is "db" (the service name).
# For an external/managed database substitute the real host and credentials.
DATABASE_URL=postgresql+asyncpg://mrv_user:change_me_in_production@db:5432/bluecarbon

# Supabase direct connection string (used by backend scripts and migrations).
# Leave empty when using the docker-compose PostgreSQL service above.
DB_URL=


# -----------------------------------------------------------------------------
# Supabase (frontend + backend)
# -----------------------------------------------------------------------------
# Your Supabase project URL — found in the Supabase dashboard under Settings > API.
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key — safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — server-side only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>


# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Full public URL of the FastAPI backend, used by the Next.js frontend.
# For local development: http://127.0.0.1:8000
# For production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Comma-separated list of allowed CORS origins for the backend.
# Add your frontend domain(s) here.
# Example: https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# Google Earth Engine (backend satellite integration)
# -----------------------------------------------------------------------------
# Path to a GEE service-account credentials JSON file, or leave empty to use
# the application-default credentials (gcloud auth application-default login).
GOOGLE_APPLICATION_CREDENTIALS=


# -----------------------------------------------------------------------------
# (Optional) APScheduler / background jobs
# -----------------------------------------------------------------------------
# Set to "false" to disable the automatic satellite ingestion scheduler.
SCHEDULER_ENABLED=true
